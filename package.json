{
  "name": "takt-starter",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "wp-scripts start --webpack-src-dir=resources --output-path=public",
    "build": "wp-scripts build --webpack-src-dir=resources --output-path=public",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint \"blocks/**/*.{ts,tsx}\" \"parts/**/*.{ts,tsx}\" --max-warnings=0 && prettier --check \"blocks/**/*.{ts,tsx,css}\" \"parts/**/*.{ts,tsx}\" \"resources/**/*.{ts,tsx,css,js}\"",
    "lint:fix": "eslint \"blocks/**/*.{ts,tsx}\" \"parts/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"blocks/**/*.{ts,tsx,css}\" \"parts/**/*.{ts,tsx}\" \"resources/**/*.{ts,tsx,css,js}\"",
    "format:check": "prettier --check \"blocks/**/*.{ts,tsx,css}\" \"parts/**/*.{ts,tsx}\" \"resources/**/*.{ts,tsx,css,js}\"",
    "phpcs": "vendor/bin/phpcs",
    "phpcbf": "vendor/bin/phpcbf",
    "phpcs:fix": "vendor/bin/phpcbf",
    "check": "bun run typecheck && bun run phpcs",
    "check:ts": "bun run typecheck"
  },
  "keywords": [],
  "author": {
    "name": "Takt",
