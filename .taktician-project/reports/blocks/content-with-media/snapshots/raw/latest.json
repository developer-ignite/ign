    "content": "<!-- wp:takt/demo-container {\"title\":\"Image Gallery - Full Content\",\"description\":\"Gallery layout with eyebrow, heading, paragraph, and button\"} -->\n\t<!-- wp:takt/content-with-media {\"eyebrow\":\"Work Integrated Learning Initiative\",\"heading\":\"Featured Student Story\",\"images\":[{\"id\":19,\"focalPoint\":{\"x\":0.5,\"y\":0.5}},{\"id\":18,\"focalPoint\":{\"x\":0.5,\"y\":0.5}},{\"id\":17,\"focalPoint\":{\"x\":0.5,\"y\":0.5}}],\"posterImage\":{\"id\":19,\"focalPoint\":{\"x\":0.5,\"y\":0.5}}} -->\n\t\t<!-- wp:paragraph -->\n\t\t<p>Diam sed vestibulum et aliquam dignissim velit nulla. Orci ac aliquam justo amet sed. Porttitor nibh in lectus lectus enim nulla phasellus tellus commodo. Experience hands-on learning that prepares you for real-world challenges.</p>\n\t\t<!-- /wp:paragraph -->\n\n\t\t<!-- wp:takt/button-row -->\n\t\t\t<!-- wp:takt/button {\"button\":{\"url\":\"#\",\"variation\":\"primary\",\"title\":\"Learn More\"}} /-->\n\t\t\t<!-- wp:takt/button {\"button\":{\"url\":\"#\",\"variation\":\"secondary\",\"title\":\"Contact Us\"}} /-->\n\t\t<!-- /wp:takt/button-row -->\n\t<!-- /wp:takt/content-with-media -->\n<!-- /wp:takt/demo-container -->\n\n<!-- wp:takt/demo-container {\"title\":\"Image Gallery - Reversed\",\"description\":\"Gallery layout with reversed columns (media on right)\"} -->\n\t<!-- wp:takt/content-with-media {\"isReversed\":true,\"eyebrow\":\"Innovation Hub\",\"heading\":\"Research Excellence\",\"images\":[{\"id\":17,\"focalPoint\":{\"x\":0.5,\"y\":0.5}},{\"id\":19,\"focalPoint\":{\"x\":0.5,\"y\":0.5}},{\"id\":18,\"focalPoint\":{\"x\":0.5,\"y\":0.5}}],\"posterImage\":{\"id\":17,\"focalPoint\":{\"x\":0.5,\"y\":0.5}}} -->\n\t\t<!-- wp:paragraph -->\n\t\t<p>Our research facilities provide cutting-edge technology and collaborative spaces for groundbreaking discoveries.</p>\n\t\t<!-- /wp:paragraph -->\n\n\t\t<!-- wp:takt/button-row -->\n\t\t\t<!-- wp:takt/button {\"button\":{\"url\":\"#\",\"variation\":\"primary\",\"title\":\"Explore Research\"}} /-->\n\t\t<!-- /wp:takt/button-row -->\n\t<!-- /wp:takt/content-with-media -->\n<!-- /wp:takt/demo-container -->\n\n<!-- wp:takt/demo-container {\"title\":\"Single Image - Dark Mode\",\"description\":\"Single image layout with dark mode background\"} -->\n\t<!-- wp:takt/content-with-media {\"darkMode\":true,\"eyebrow\":\"Campus Life\",\"heading\":\"Student Experience\",\"headingSize\":\"small\",\"imageLayout\":\"single\",\"images\":[{\"id\":18,\"focalPoint\":{\"x\":0.5,\"y\":0.5}},{\"id\":null,\"focalPoint\":{\"x\":0.5,\"y\":0.5}},{\"id\":null,\"focalPoint\":{\"x\":0.5,\"y\":0.5}}],\"posterImage\":{\"id\":18,\"focalPoint\":{\"x\":0.5,\"y\":0.5}}} -->\n\t\t<!-- wp:paragraph -->\n\t\t<p>Join a vibrant community of students from diverse backgrounds. Engage in extracurricular activities, clubs, and events that enrich your university experience.</p>\n\t\t<!-- /wp:paragraph -->\n\n\t\t<!-- wp:list -->\n\t\t<ul class=\"wp-block-list\"><li>Student clubs and organizations</li><li>Cultural events and festivals</li><li>Sports and recreation facilities</li></ul>\n\t\t<!-- /wp:list -->\n\n\t\t<!-- wp:takt/button-row -->\n\t\t\t<!-- wp:takt/button {\"button\":{\"url\":\"#\",\"variation\":\"primary\",\"title\":\"Get Involved\"}} /-->\n\t\t<!-- /wp:takt/button-row -->\n\t<!-- /wp:takt/content-with-media -->\n<!-- /wp:takt/demo-container -->\n\n<!-- wp:takt/demo-container {\"title\":\"Video - YouTube Embed\",\"description\":\"Video content with YouTube embed and poster image\"} -->\n\t<!-- wp:takt/content-with-media {\"eyebrow\":\"Virtual Tour\",\"heading\":\"Explore Our Campus\",\"mediaType\":\"video\",\"videoSource\":\"youtube\",\"videoId\":\"dQw4w9WgXcQ\",\"posterImage\":{\"id\":19,\"focalPoint\":{\"x\":0.5,\"y\":0.5}}} -->\n\t\t<!-- wp:paragraph -->\n\t\t<p>Take a virtual tour of our beautiful campus and discover state-of-the-art facilities, green spaces, and historic buildings.</p>\n\t\t<!-- /wp:paragraph -->\n\n\t\t<!-- wp:quote -->\n\t\t<blockquote class=\"wp-block-quote\"><!-- wp:paragraph -->\n\t\t<p>\"The campus tour convinced me this was the right place for my education.\" - Current Student</p>\n\t\t<!-- /wp:paragraph --></blockquote>\n\t\t<!-- /wp:quote -->\n\n\t\t<!-- wp:takt/button-row -->\n\t\t\t<!-- wp:takt/button {\"button\":{\"url\":\"#\",\"variation\":\"primary\",\"title\":\"Watch Full Tour\"}} /-->\n\t\t\t<!-- wp:takt/button {\"button\":{\"url\":\"#\",\"variation\":\"secondary\",\"title\":\"Schedule Visit\"}} /-->\n\t\t<!-- /wp:takt/button-row -->\n\t<!-- /wp:takt/content-with-media -->\n<!-- /wp:takt/demo-container -->\n\n<!-- wp:takt/demo-container {\"title\":\"Minimal Content\",\"description\":\"Block with only heading and single paragraph\"} -->\n\t<!-- wp:takt/content-with-media {\"heading\":\"Academic Programs\",\"images\":[{\"id\":17,\"focalPoint\":{\"x\":0.5,\"y\":0.5}},{\"id\":18,\"focalPoint\":{\"x\":0.5,\"y\":0.5}},{\"id\":19,\"focalPoint\":{\"x\":0.5,\"y\":0.5}}],\"posterImage\":{\"id\":17,\"focalPoint\":{\"x\":0.5,\"y\":0.5}}} -->\n\t\t<!-- wp:paragraph -->\n\t\t<p>Choose from a wide range of undergraduate and graduate programs designed to meet your educational goals.</p>\n\t\t<!-- /wp:paragraph -->\n\t<!-- /wp:takt/content-with-media -->\n<!-- /wp:takt/demo-container -->",
