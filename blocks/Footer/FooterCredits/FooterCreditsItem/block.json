{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "takt/footer-credits-item",
  "title": "Legal Link",
  "category": "takt-theme",
  "description": "Individual legal/policy link in the footer credits bar",
  "parent": ["takt/footer-credits"],
  "supports": {
    "html": false,
    "anchor": true,
    "reusable": false
  },
  "attributes": {
    "anchor": { "type": "string" },
    "link": {
      "type": "object",
      "default": {
        "url": "",
        "postId": null,
        "postType": null,
        "opensInNewTab": false,
        "title": "",
        "label": ""
      }
    }
  },
  "textdomain": "takt",
  "example": {
    "viewportWidth": 300,
    "attributes": {
      "link": { "title": "Privacy Policy", "url": "#" }
    }
  }
}
