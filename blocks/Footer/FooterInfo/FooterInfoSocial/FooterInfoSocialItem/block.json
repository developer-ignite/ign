{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "takt/footer-info-social-item",
  "title": "Social Media Link",
  "category": "takt-theme",
  "description": "Individual social media icon with link",
  "parent": ["takt/footer-info-social"],
  "supports": {
    "html": false,
    "anchor": true,
    "reusable": false
  },
  "attributes": {
    "anchor": { "type": "string" },
    "link": {
      "type": "object",
      "default": {
        "title": "",
        "url": "",
        "postId": null,
        "postType": null,
        "opensInNewTab": true,
        "label": ""
      }
    },
    "logoId": { "type": "number", "default": null },
    "iconSlug": { "type": "string", "default": "" }
  },
  "textdomain": "takt",
  "example": {
    "viewportWidth": 100,
    "attributes": {
      "link": { "title": "Instagram", "url": "#" },
      "iconSlug": "instagram"
    }
  }
}
