{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "takt/text-card",
  "title": "Text Card",
  "category": "takt-theme",
  "description": "A text card for use within Masonry Cards block",
  "parent": ["takt/masonry-cards"],
  "usesContext": ["masonryCards/columnCount", "masonryCards/masonryStyle"],
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "isTall": {
      "type": "boolean",
      "default": false
    },
    "accentColor": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "takt",
  "example": {
    "viewportWidth": 400,
    "attributes": {
      "title": "90%",
      "content": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique."
    }
  }
}
